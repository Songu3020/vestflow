# VestFlow Indexer — environment variables
# Copy to .env and fill in values before running.

# Network this poller process indexes: testnet or mainnet
INDEXER_NETWORK=testnet

# Stellar RPC endpoints
RPC_URL_TESTNET=https://soroban-testnet.stellar.org
RPC_URL_MAINNET=https://mainnet.sorobanrpc.com

# VestFlow Soroban contract addresses
CONTRACT_ID_TESTNET=CCZ6AE75C27DMB3SOIHK7WZSBUG3NQPVLHSVEBQ2FSAEVGRJ5TXAZWCX
CONTRACT_ID_MAINNET=

# Absolute paths to the SQLite database files
# Defaults to vestflow-events-testnet.db and vestflow-events-mainnet.db
INDEXER_DB_PATH_TESTNET=./vestflow-events-testnet.db
INDEXER_DB_PATH_MAINNET=./vestflow-events-mainnet.db

# Polling interval in milliseconds (default: 10 seconds)
POLL_INTERVAL_MS=10000

# TVL aggregation interval in milliseconds (default: 60 seconds)
TVL_COMPUTE_INTERVAL_MS=60000

# Ledger to start from on first run (0 = latest ledger from RPC)
# Set to a specific ledger number to replay history from that point.
START_LEDGER=0

# Port for the query HTTP server
INDEXER_PORT=3001
